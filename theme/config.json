{
    "name": "openrealm",
    "description": "OpenRealm — Modern Vue 3 Theme",
    "version": "1.0.0",
    "configs": [
        {
            "label": "界面主题",
            "placeholder": "请选择界面主题",
            "field_name": "or_theme",
            "field_type": "select",
            "select_options": {
                "light": "浅色",
                "dark": "深色",
                "violet": "紫色"
            },
            "default_value": "light"
        },
        {
            "label": "界面语言",
            "placeholder": "请选择语言",
            "field_name": "or_locale",
            "field_type": "select",
            "select_options": {
                "zh-CN": "简体中文",
                "en": "English"
            },
            "default_value": "zh-CN"
        },
        {
            "label": "自定义 HTML",
            "placeholder": "可插入统计代码等",
            "field_name": "custom_html",
            "field_type": "textarea",
            "default_value": ""
        }
    ]
}
